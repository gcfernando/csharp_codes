<Project Sdk="Microsoft.NET.Sdk">

  <!-- ===========================================================================
       Glass.Message — class library project.
       Developer ::> Gehan Fernando
       =========================================================================== -->

  <!-- Target frameworks & language -->
  <PropertyGroup>
    <!-- Windows-only library; ship for .NET Framework 4.8.1 and modern .NET. -->
    <TargetFrameworks>net481;net8.0-windows;net9.0-windows;net10.0-windows</TargetFrameworks>
    <UseWindowsForms>true</UseWindowsForms>
    <OutputType>Library</OutputType>
    <AssemblyName>Glass.Message</AssemblyName>
    <RootNamespace>Glass</RootNamespace>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU</Platforms>
    <NeutralLanguage>en</NeutralLanguage>
  </PropertyGroup>

  <!-- Build quality and reproducibility -->
  <PropertyGroup>
    <!-- Reproducible binaries; CI sets $(CI) to also normalise source paths. -->
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild Condition="'$(CI)' == 'true'">true</ContinuousIntegrationBuild>
    <!-- Faster incremental builds for downstream projects. -->
    <ProduceReferenceAssembly>true</ProduceReferenceAssembly>
    <!-- Roslyn analyzers on, reported as warnings (build is not failed by them). -->
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <!-- Suppress auto-generated AssemblyInfo so Properties\AssemblyInfo.cs is authoritative. -->
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Emit XML docs for IntelliSense; 1591 = "missing doc" is silenced because
         internal members are intentionally undocumented, and CA1416 because the
         whole library is Windows-only by design. -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);1591;CA1416</NoWarn>
  </PropertyGroup>

  <!-- Release-only optimisation -->
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>Glass.Message</PackageId>
    <Title>Glass.Message</Title>
    <Version>1.0.0.0</Version>
    <Authors>Gehan Fernando</Authors>
    <Company>Gehan Fernando</Company>
    <Product>Glass.Message</Product>
    <Description>Next-level modern replacement for MessageBox on Windows — Mica/Acrylic backdrop, auto dark/light theme, animations, toast notifications, async API, inline input, countdown, expandable detail, progress bar, RTL, and more. Drop-in compatible: GlassMessage.Show(...) compiles as-is.</Description>
    <PackageTags>messagebox dialog winforms windows11 windows10 fluent glass mica acrylic toast notification dark-mode dpi-aware</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>Copyright © 2026 Gehan Fernando</Copyright>
    <RepositoryType>git</RepositoryType>
    <!-- Ship a debug-symbols (.snupkg) package alongside the main one. -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <!--
    Visual Studio design-time builds and MSBuild solution-level orchestration may call
    ResolveProjectReferences on this project's outer cross-targeting build (where TargetFramework
    is empty and the SDK does not import Microsoft.Common.CurrentVersion.targets, so the real
    ResolveProjectReferences is absent).  Glass.Message has no <ProjectReference> items, so this
    stub is identical in effect to the SDK-provided target — it just prevents the build error.
  -->
  <Target Name="ResolveProjectReferences" Condition="'$(TargetFramework)' == ''" />

  <!-- Auto-sign every output DLL with the dev Authenticode cert (run tools\Setup-DevCert.ps1 once first).
       Condition skips the outer cross-targeting build (TargetFramework empty), where $(TargetPath) is
       blank and signtool would otherwise be invoked with an empty path. -->
  <Target Name="SignOutput" AfterTargets="Build" Condition="'$(TargetFramework)' != ''">
    <PropertyGroup>
      <_SignScript>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\tools\Sign-Output.ps1'))</_SignScript>
      <_ThumbprintFile>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\tools\cert-thumbprint.txt'))</_ThumbprintFile>
    </PropertyGroup>
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(_SignScript)&quot; -TargetPath &quot;$(TargetPath)&quot; -ThumbprintFile &quot;$(_ThumbprintFile)&quot;"
          ContinueOnError="true" />
  </Target>

  <!-- .NET Framework 4.8.1 — explicit references (WinForms assemblies not auto-resolved on this TFM) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net481'">
    <Reference Include="System" />
    <Reference Include="System.Core" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
  </ItemGroup>

</Project>
