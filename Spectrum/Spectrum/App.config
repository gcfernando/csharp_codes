<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
	</startup>
	<appSettings>
		<clear/>
		<!-- Visual Modes: Choose based on music type and use case -->
		<!-- Spectrum:	Ultra-fast analyzer - Best for: EDM, Hip-Hop, DJ mixing, mastering, real-time frequency analysis -->
		<!-- Bricks:	Retro block aesthetic - Best for: 80s music, Synthwave, Chiptune, pixel art style, party visuals -->
		<!-- LED:		Professional peak meter - Best for: Recording studios, Broadcasting, Live monitoring, accurate level checking -->
		<!-- Dots:		Smooth minimal style - Best for: Ambient music, Minimal techno, Background visualization, elegant aesthetics -->
		<!-- Wave:		Flowing organic motion - Best for: Chill-hop, Lo-fi, Podcasts, Relaxing content, smooth animations -->
		<!-- Pulse:		Breathing hypnotic effect - Best for: Meditation, Downtempo, Ambient, Yoga, Lounge music -->
		<!-- Center:	Energy from center - Best for: Orchestral, Cinematic, Film scores, Wide stereo content, Classical music -->
		<!-- Mirror:	Symmetrical balance - Best for: EDM, House music, Beat matching, Symmetrical compositions, Techno -->

		<!-- DEFAULT RECOMMENDATION: Use "Spectrum" for all-around best performance - works perfectly with any music genre, real-time response, beautiful and accurate -->
		<add key="Mode" value="Spectrum"/>
	</appSettings>
</configuration>